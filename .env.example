
# DATABASE
# REQUIRES BACKEND API ROUTE
DATABASE_URL=postgresql://user:password@localhost:5432/zenflow

# AUTH
# REQUIRES AUTH INTEGRATION
JWT_SECRET=your_jwt_secret_here
NEXTAUTH_SECRET=your_nextauth_secret_here

# PAYMENT API (M-Pesa Daraja)
# REQUIRES PAYMENT VERIFICATION
MPESA_CONSUMER_KEY=your_mpesa_key
MPESA_CONSUMER_SECRET=your_mpesa_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=4088222

# SMS API (Africa's Talking)
# REQUIRES ENV VARIABLE
AT_USERNAME=sandbox
AT_API_KEY=your_at_api_key

# APP CONFIG
# REQUIRES ENV VARIABLE
APP_URL=http://localhost:3000
NODE_ENV=development
